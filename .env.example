SERVICE_NAME=Rolley Service
SERVICE_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./rolley.db
# Production Postgres example:
# DATABASE_URL=postgresql://postgres:password@banter-postgres:5432/postgres
CORS_ORIGINS=*

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Sports provider api key (optional)
SPORTS_API_KEY=
SPORTS_PROVIDER=ESPN
SOCCER_COMPETITIONS=eng.1,esp.1,ger.1,ita.1,fra.1,uefa.champions,uefa.europa,uefa.europa.conf,ned.1,por.1,bel.1,sco.1,sui.1,aut.1,swe.1,nor.1,den.1,usa.1,mex.1,bra.1,arg.1,aus.1,jpn.1,chn.1,ksa.1
BASKETBALL_COMPETITIONS=nba
SAME_DAY_ONLY=true
SOCCER_EVENT_TIMEZONE=UTC
BASKETBALL_EVENT_TIMEZONE=America/New_York
SPORTS_FALLBACK_TO_STUB=false
API_FOOTBALL_ENABLED=false
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
FOOTBALL_DATA_ENABLED=false
FOOTBALL_DATA_KEY=
ODDS_API_ENABLED=true
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.odds-api.io/v3
ODDS_API_BOOKMAKERS=Bet365,Pinnacle,Unibet
ODDS_API_MATCH_WINDOW_HOURS=8
ODDS_SANITY_FILTER_ENABLED=true
ODDS_SANITY_DOUBLE_CHANCE_MAX=1.35
ODDS_SANITY_TOTAL_GOALS_OVER_05_MAX=1.30
ODDS_SANITY_TOTAL_GOALS_OVER_15_MAX=1.55
ODDS_SANITY_HANDICAP_MAX=1.50

# Protect manual refresh endpoint
ADMIN_REFRESH_KEY=

# Daily cron in UTC
CRON_ENABLED=true
CRON_HOUR_UTC=8
CRON_MINUTE_UTC=0
AUTO_SETTLEMENT_ENABLED=true
AUTO_SETTLEMENT_HOUR_UTC=2
AUTO_SETTLEMENT_MINUTE_UTC=30
AUTO_SETTLEMENT_OFFSET_DAYS=1

DEFAULT_PICK_COUNT=10
PRIMARY_PICK_COUNT=1
PRIMARY_MIN_COMPLETENESS=0.65
PREDICTION_MIN_CONFIDENCE=0.90
PREDICTION_MIN_CONFIDENCE_SOCCER=0.75
PREDICTION_MIN_CONFIDENCE_BASKETBALL=0.65
PREDICTION_MAX_PICKS_PER_SPORT=3
PREDICTION_EXCLUDE_STARTED_MATCHES=true
PREDICTION_START_BUFFER_MINUTES=0
SOCCER_PRIMARY_PREFER_SAFE_MARKETS=true
SOCCER_PRIMARY_ALLOW_HANDICAP_FALLBACK=true
SOCCER_SUPPORTED_HANDICAP_LINES=1.5
TRUSTED_SOCCER_COMPETITIONS=eng.1,esp.1,ger.1,ita.1,fra.1,uefa.champions,uefa.europa,uefa.europa.conf,tur.1
HIGH_RISK_SOCCER_COMPETITIONS=vie.1,tur.2,tur.3
TRUSTED_BASKETBALL_COMPETITIONS=nba
LEAGUE_RISK_BLOCK_HIGH_RISK_PRIMARY=true
LEAGUE_RISK_CONFIDENCE_PENALTY=0.12
LEAGUE_RISK_PENALIZE_UNTRUSTED=false

# XGBoost model inference
XGBOOST_ENABLED=true
XGBOOST_MODEL_PATH=./models/rolley_xgb_v1.json
XGBOOST_FEATURE_NAMES=h2h_home_win_rate,h2h_draw_rate,h2h_away_win_rate,home_form_index,away_form_index,urgency_score,volatility_index,injury_impact,fatigue_level,weather_impact,home_edge,h2h_sample_size,home_recent5_scored_rate,away_recent5_scored_rate,home_recent5_goal_diff,away_recent5_goal_diff,home_recent5_opponent_strength,away_recent5_opponent_strength

# Movement integration
MOVEMENT_ENABLED=false
MOVEMENT_NETWORK=testnet
MOVEMENT_NODE_URL=https://testnet.movementnetwork.xyz/v1
MOVEMENT_EXPLORER_BASE=https://explorer.movementnetwork.xyz
MOVEMENT_ROL_DECIMALS=8
MOVEMENT_PRIVATE_KEY=
MOVEMENT_ACCOUNT_ADDRESS=
MOVEMENT_TOKEN_MODULE_ADDRESS=
MOVEMENT_SETTLEMENT_MODULE_ADDRESS=
MOVEMENT_ROL_METADATA_ADDRESS=
MOVEMENT_PICK_METADATA_BASE_URL=https://sportbanter.online/rolley/picks
