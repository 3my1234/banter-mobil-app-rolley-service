SERVICE_NAME=Rolley Service
SERVICE_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./rolley.db
CORS_ORIGINS=*

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Sports provider api key (optional)
SPORTS_API_KEY=

# Protect manual refresh endpoint
ADMIN_REFRESH_KEY=

# Daily cron in UTC
CRON_ENABLED=true
CRON_HOUR_UTC=8
CRON_MINUTE_UTC=0

DEFAULT_PICK_COUNT=10
