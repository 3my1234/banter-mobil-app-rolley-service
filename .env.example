SERVICE_NAME=Rolley Service
SERVICE_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./rolley.db
CORS_ORIGINS=*

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Sports provider api key (optional)
SPORTS_API_KEY=
SPORTS_PROVIDER=ESPN
SOCCER_COMPETITIONS=eng.1,esp.1,ger.1,ita.1,fra.1
BASKETBALL_COMPETITIONS=nba
SAME_DAY_ONLY=true
SPORTS_FALLBACK_TO_STUB=false

# Protect manual refresh endpoint
ADMIN_REFRESH_KEY=

# Daily cron in UTC
CRON_ENABLED=true
CRON_HOUR_UTC=8
CRON_MINUTE_UTC=0

DEFAULT_PICK_COUNT=10
PRIMARY_PICK_COUNT=1

# XGBoost model inference
XGBOOST_ENABLED=true
XGBOOST_MODEL_PATH=./models/rolley_xgb_v1.json
XGBOOST_FEATURE_NAMES=h2h_home_win_rate,h2h_draw_rate,h2h_away_win_rate,home_form_index,away_form_index,urgency_score,volatility_index,injury_impact,fatigue_level,weather_impact,home_edge
